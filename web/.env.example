# Copy to web/.env.local — never commit .env.local to GitHub.
# Get values from Supabase: Project Settings → API (URL + anon key)
# and Settings → Database (connection string, optional for CLI/migrations).

# ─── Public (safe in browser) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth buttons shown in the app (provider must also be enabled in Supabase Dashboard).
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_OAUTH_APPLE_ENABLED=false
NEXT_PUBLIC_OAUTH_FACEBOOK_ENABLED=false

# ─── Server-only secrets (never expose to the client) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Local dev only — skip email confirmation and sign in immediately after signup.
# Leave unset or false in production so users must click the verification link.
AUTH_SKIP_EMAIL_CONFIRMATION=false

# Comma-separated emails that can access /dashboard/admin (your login only).
GOTREFS_ADMIN_EMAILS=gotrefsadmin@gmail.com

# Direct Postgres connection (optional — Supabase CLI, scripts, admin tools).
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Used to sign session-related tokens if you add custom server sessions later.
# Generate: openssl rand -base64 32
AUTH_SECRET=

# OAuth provider app credentials.
# In this Supabase Auth setup, configure these in Supabase Dashboard → Authentication → Providers.
# Keep matching values in Vercel only if you later add direct provider-token verification.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Checkr background screening (production)
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=

# Optional — powers the FAQ "Ask" AI helper on the marketing site
OPENAI_API_KEY=
