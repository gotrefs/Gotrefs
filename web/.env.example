# Copy to web/.env.local — never commit .env.local to GitHub.
# Get values from Supabase: Project Settings → API (URL + anon key)
# and Settings → Database (connection string, optional for CLI/migrations).

# ─── Public (safe in browser) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# New publishable key (sb_publishable_...) or legacy anon JWT — use one:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server-only secrets (never expose to the client) ─────────────────────────
# New secret key (sb_secret_...) or legacy service_role JWT — use one:
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Postgres connection (optional — Supabase CLI, scripts, admin tools).
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Used to sign session-related tokens if you add custom server sessions later.
# Generate: openssl rand -base64 32
AUTH_SECRET=

# OAuth provider app credentials.
# In this Supabase Auth setup, configure these in Supabase Dashboard → Authentication → Providers.
# Keep matching values in Vercel only if you later add direct provider-token verification.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Checkr background screening (production)
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=

# Optional — powers the FAQ "Ask" AI helper on the marketing site
OPENAI_API_KEY=

# Platform admin (comma-separated auth user UUIDs for verification review queue)
PLATFORM_ADMIN_USER_IDS=

# NSID verification integration (future)
NSID_REVIEW_URL=
NSID_WEBHOOK_SECRET=
